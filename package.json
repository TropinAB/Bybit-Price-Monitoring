{
  "name": "ts-template",
  "version": "1.0.0",
  "description": "TS-Template",
  "private": true,
  "scripts": {
    "build": "set NODE_ENV='production' && webpack --mode=production",
    "build:dev": "set NODE_ENV='development' && webpack --mode=development",
    "dev": "set NODE_ENV='development' && webpack serve --mode=development",
    "test": "jest",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "type-check": "tsc --noEmit --strict --noUnusedLocals --noUnusedParameters --pretty",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TropinAB/TS-Template.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/TropinAB/TS-Template/issues"
  },
  "homepage": "https://github.com/TropinAB/TS-Template#readme",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.1",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.2.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.2.0",
    "globals": "^16.5.0",
    "html-webpack-plugin": "^5.6.6",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "3.6.2",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix",
    "*.{js,ts,css,md,yml,html}": "prettier --write"
  }
}
